    {
      "parameters": {
        "jsCode": "const today = new Date($input.first().json.fields['End date']);\n\n// Get current expiry date from Airtable record\nconst currentExpiry = new Date($input.first().json.fields['Expiry Date']);\n\n// If they're renewing early, new start = current expiry date\n// If already expired, new start = today\nconst startDate = currentExpiry > today ? currentExpiry : today;\n\n// Add 90 days (3 months)\nconst expiryDate = new Date(startDate);\nexpiryDate.setDate(expiryDate.getDate() + 90);\n\nreturn [{\n  json: {\n    recordId: $input.first().json.id,\n    memberName: $input.first().json.fields['Full Name'],\n    memberEmail: $input.first().json.fields['Email Address'],\n    newStartDate: startDate.toISOString().split('T')[0],\n    newExpiryDate: expiryDate.toISOString().split('T')[0],\n  }\n}];"
      },
