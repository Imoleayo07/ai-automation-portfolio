    {
      "parameters": {
        "jsCode": "return $input.all().map(item => {\n  const name = item.json['Customer Name'].split(' ')[0];\n  const category = item.json['Category'];\n  const days = item.json.daysSinceOrder;\n  const segment = item.json.segment;\n\n  let offer = '';\n  if (segment === 'VIP') {\n    offer = `As one of our most valued customers, we'd love to give you exclusive early access to our newest ${category} arrivals before anyone else.`;\n  } else if (segment === 'Standard') {\n    offer = `We'd love to welcome you back with free shipping on your next ${category} order — no minimum spend required.`;\n  } else {\n    offer = `We'd love to welcome you back with 15% off your next order. Use code WINBACK15 at checkout.`;\n  }\n\n  let email = `Hi ${name},\n\nWe noticed it's been ${days} days since your last order and we genuinely miss you. Your taste in ${category} is amazing and we'd love to see you back.\n\n${offer}\n\nClick below to shop now — we've got some great new items we think you'll love.\n\nWarm regards,\nThe Team`;\n\n  email = email\n    .replace(/\\*+/g, '')\n    .replace(/^\\s*-\\s+/gm, '')\n    .replace(/\\s*-{2,}\\s*/g, ' ')\n    .replace(/[ \\t]+/g, ' ')\n    .replace(/\\n{3,}/g, '\\n\\n')\n    .trim();\n\n  return {\n    json: {\n      ...item.json,\n      emailBody: email,\n      emailSubject: `We miss you, ${name} — here's something special`,\n    }\n  };\n});"
      },
