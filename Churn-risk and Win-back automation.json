    {
      "parameters": {
        "jsCode": "const customers = {};\n\nfor (const item of $input.all()) {\n  const email = item.json['Customer Email'];\n  if (!email) continue;\n\n  if (!customers[email]) {\n    customers[email] = {\n      'Customer Email': email,\n      'Customer Name': item.json['Customer Name'],\n      'Category': item.json['Category'],\n      'Order Date': item.json['Order Date'],\n      'Revenue ($)': item.json['Revenue ($)'] || 0,\n    };\n  } else {\n    // Keep the most recent order date\n    if (item.json['Order Date'] > customers[email]['Order Date']) {\n      customers[email]['Order Date'] = item.json['Order Date'];\n    }\n    // Sum up total revenue\n    customers[email]['Revenue ($)'] += item.json['Revenue ($)'] || 0;\n  }\n}\n\nreturn Object.values(customers).map(c => ({ json: c }));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -176,
        0
      ],
      "id": "e30c54b3-d00f-44a3-bdf5-2140dc76bfe3",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "jsCode": "const today = new Date();\n\nreturn $input.all().map(item => {\n  const lastOrder = new Date(item.json['Order Date']);\n  const days = Math.floor((today - lastOrder) / (1000 * 60 * 60 * 24));\n  \n  const revenue = item.json['Revenue ($)'];\n  const segment = revenue >= 5000 ? 'VIP' \n                : revenue >= 1000 ? 'Standard' \n                : 'Low value';\n\n  return {\n    json: {\n      ...item.json,\n      daysSinceOrder: days,\n      churnRisk: days >= 90 ? 'high' : days >= 60 ? 'medium' : 'low',\n      segment: segment,\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
